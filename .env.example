# RENOMBRA ESTE ARCHIVO A .env Y COLOCA TUS CLAVES REALES AQUÍ
# NO COMPARTAS ESTE ARCHIVO PÚBLICAMENTE

# Token de tu bot de Telegram obtenido a través de @BotFather
TELEGRAM_BOT_TOKEN="tu_token_aqui_obtenido_de_botfather"

# API Key de OpenAI (Empieza con sk-...)
OPENAI_API_KEY="tu_openai_api_key_aqui"

# Seguridad opcional del bot y webhook
# Lista separada por comas de chat_ids autorizados. Si queda vacía, JARVIS acepta cualquier chat.
AUTHORIZED_CHAT_IDS="123456789"

# Protección opcional para el dashboard web con Basic Auth
DASHBOARD_USER="admin"
DASHBOARD_PASSWORD="cambia_esto"
